def style_ax(ax, title, xlabel="", ylabel=""):
    ax.set_facecolor(UFC_PANEL)
    ax.set_title(title, color=UFC_WHITE, fontsize=10.5, fontweight="bold", pad=9, loc="left")
    if xlabel: ax.set_xlabel(xlabel, color=UFC_SILVER, fontsize=8.5, labelpad=5)
    if ylabel: ax.set_ylabel(ylabel, color=UFC_SILVER, fontsize=8.5, labelpad=5)
    ax.tick_params(colors=UFC_SILVER, labelsize=8)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["bottom"].set_color(UFC_GREY)
    ax.spines["left"].set_color(UFC_GREY)

def red_line(ax, val=50):
    ax.axhline(val, color=UFC_RED, lw=1.2, ls="--", alpha=0.65)


